# Perplexity session cookie (next-auth.session-token value)
PPLX_COOKIE=

# API key for authenticating requests to this proxy
PPLX_PROXY_API_KEY=

# Port
PPLX_PROXY_PORT=8892

# Session keep-alive interval (hours)
KEEPALIVE_HOURS=6

LOG_LEVEL=INFO

# ntfy.sh push notification
NTFY_TOPIC=pplx-proxy
NTFY_COOLDOWN_SECS=3600

# Default model for API/MCP when not specified
DEFAULT_MODEL=pplx-auto

# Public URL for ntfy notification links
PUBLIC_URL=http://localhost:8892

# Perplexity internal API version
PPLX_API_VERSION=2.18

# curl_cffi TLS impersonation target
PPLX_IMPERSONATE=chrome

# Cookie cache max age (hours)
COOKIE_MAX_AGE_HOURS=168
