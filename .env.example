# Perplexity session cookie (next-auth.session-token value from browser)
PPLX_COOKIE=

# API key for authenticating requests to this proxy (empty = no auth)
PPLX_PROXY_API_KEY=

# Perplexity account tier: free, pro, max
ACCOUNT_TYPE=pro

# Default model when not specified in request
DEFAULT_MODEL=pplx-gpt5

# Port
PPLX_PROXY_PORT=8892

# Session keep-alive interval (hours)
KEEPALIVE_HOURS=6

# Auto-discovery probe interval (hours)
PROBE_INTERVAL_HOURS=24

# ntfy.sh push notification
NTFY_TOPIC=pplx-proxy
NTFY_COOLDOWN_SECS=3600

# Public URL (used in ntfy notification messages)
PUBLIC_URL=http://localhost:8892

# Perplexity internal API version
PPLX_API_VERSION=2.18

# curl_cffi TLS fingerprint target
PPLX_IMPERSONATE=chrome

# HTTP User-Agent
USER_AGENT=Mozilla/5.0 (X11; Linux aarch64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/130.0.0.0 Safari/537.36

# Cookie cache max age (hours)
COOKIE_MAX_AGE_HOURS=168

LOG_LEVEL=INFO
